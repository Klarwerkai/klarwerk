# Kopie als .env anlegen. NIEMALS .env committen.

# --- Server ---
PORT=3000
# Basis-URL der App (für Links in E-Mails, z. B. Passwort-Reset).
APP_BASE_URL=https://app.klarwerk.ai
# Secure-Cookies nur über HTTPS senden — in Produktion auf true.
COOKIE_SECURE=true

# --- Datenbank ---
# Ohne DATABASE_URL läuft die App In-Memory (lokaler Schnellstart). Mit → Postgres.
DATABASE_URL=postgresql://klarwerk:klarwerk_dev@localhost:5432/klarwerk

# --- Reasoner (KI), optional ---
# Ohne Schlüssel: deterministischer Fallback. Mit Schlüssel: echtes Modell.
ANTHROPIC_API_KEY=
REASONER_MODEL=claude-sonnet-4-6

# --- E-Mail (SMTP), optional (FR-AUTH-08 Reset, FR-VAL-07 Benachrichtigungen) ---
# Anbieteragnostisch. Ohne SMTP_HOST: kein Versand. Transaktions-Versender empfohlen
# (EU: Brevo/Mailjet); info@klarwerk.ai bleibt M365 für Menschen.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@klarwerk.ai
SMTP_SECURE=false

# --- SSO / OIDC, optional (FR-AUTH-07) — Authorization Code + PKCE (S256) ---
# SSO ist nur aktiv, wenn ISSUER/AUDIENCE/JWKS_URI/AUTHORIZE_URL/TOKEN_URL/CLIENT_ID/
# REDIRECT_URI gesetzt sind (sonst zeigt das Login SSO ehrlich als deaktiviert).
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
OIDC_CLIENT_ID=
# REDIRECT_URI = öffentliche App-URL + /sso/callback (beim IdP exakt so registrieren).
OIDC_REDIRECT_URI=https://app.klarwerk.ai/sso/callback
# Nur bei "confidential client" nötig; bei public client (nur PKCE) leer lassen.
OIDC_CLIENT_SECRET=
OIDC_AUTOPROVISION=false
# Rollen-Mapping aus Claims (Default-Rolle viewer; Admin NUR bei exakt gesetzter Gruppe).
OIDC_ROLE_CLAIM=roles
OIDC_GROUP_ADMIN=
OIDC_GROUP_CONTROLLER=
OIDC_GROUP_EXPERTE=
