<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">
  <!-- WP-KLARA-1: Word-Taskpane-Add-in "Klara" (Sideload). Das Taskpane liegt AUF der App-Domain
       (public/word-addin/), daher same-origin API-Zugriff mit Session-Cookie. app.klarwerk.ai leitet
       serverseitig 301 auf klarwerk.ai um — beide Domains stehen deshalb in den AppDomains.
       WP-KLARA-1c (Pedis Sideload-Befund, Word Mac 16.111): Kommentare stehen bewusst NACH dem
       Root-Element-Start — ein Kommentar-Header VOR <OfficeApp> war vermutlich Mitursache, dass das
       Add-in im Sideload nicht erschien. Vor dem Kopieren in den wef-Ordner nichts umbauen. -->
  <Id>7f6b1c9e-4a2d-4e8f-9b3a-2c5d8e7f1a64</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>KLARWERK</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>
  <DisplayName DefaultValue="Klara" />
  <Description DefaultValue="Klara verbindet Word mit KLARWERK: markierten Text als Wissens-Entwurf senden — ehrlich, ohne Automatik." />
  <IconUrl DefaultValue="https://app.klarwerk.ai/word-addin/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://app.klarwerk.ai/word-addin/icon-80.png" />
  <SupportUrl DefaultValue="https://app.klarwerk.ai/" />
  <AppDomains>
    <AppDomain>https://app.klarwerk.ai</AppDomain>
    <AppDomain>https://klarwerk.ai</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WordApi" MinVersion="1.1" />
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://app.klarwerk.ai/word-addin/taskpane.html" />
  </DefaultSettings>
  <!-- WP-KLARA-1b (K3, Least-Privilege): bis KLARA-2 las das Add-in nur die Selektion — ReadDocument.
       WP-KLARA-ASK (Teil 2, Pedis Entscheid 22.07.): "Antwort in Word einfuegen" ist eine bewusste
       Dokument-MUTATION (setSelectedDataAsync an der Cursorposition) — ReadWriteDocument ist jetzt die
       kleinste ausreichende Stufe (Office kennt keine feinere Schreib-Berechtigung fuers Taskpane). -->
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
