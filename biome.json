{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "complexity": { "noUselessTypeConstraint": "error" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "**/dist",
      "**/test-results",
      "**/playwright-report",
      "**/node_modules",
      "docs/generated",
      "docs/ci/brand-book",
      "UI:UX",
      "Blueprint",
      "**/*.tsbuildinfo",
      "**/*.timestamp-*.mjs",
      "scripts"
    ]
  }
}
