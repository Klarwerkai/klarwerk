{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "complexity": { "noUselessTypeConstraint": "error" }
    }
  },
  "overrides": [
    {
      "include": ["tsconfig.tests-tsx.json"],
      "json": { "parser": { "allowComments": true } }
    },
    {
      "include": ["**/*.test.ts"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "performance": { "noDelete": "off" }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "**/dist",
      "**/test-results",
      "**/playwright-report",
      "**/node_modules",
      "docs/generated",
      "docs/ci/brand-book",
      "docs/team2-austausch",
      "UI:UX",
      "Blueprint",
      "**/*.tsbuildinfo",
      "**/*.timestamp-*.mjs",
      "scripts",
      "services/app/addin-static"
    ]
  }
}
