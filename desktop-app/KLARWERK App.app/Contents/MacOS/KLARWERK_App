#!/bin/bash
# KLARWERK App – Desktop-Starter (Team 1)
# Doppelklick: liest die API-Keys aus dem macOS-Schlüsselbund (Erststart: verdeckte Dialoge),
# baut das Frontend falls nötig, startet den Monolithen (SPA + /api aus einem Prozess)
# und öffnet den Browser. Kein Terminal. Keys landen NIE in Dateien oder Logs.

# Rosetta-Falle: LaunchServices startet Script-Apps teils unter x86_64-Emulation,
# obwohl der Mac Apple Silicon ist. Dann sofort nativ (arm64) neu starten.
if [ "$(/usr/bin/uname -m)" = "x86_64" ] && [ "$(/usr/sbin/sysctl -n hw.optional.arm64 2>/dev/null)" = "1" ]; then
  exec /usr/bin/arch -arm64 /bin/bash "$0" "$@"
fi

REPO="/Users/peterkohnert/Documents/dev_Klarwerk"
PORT=3000
LOG="$REPO/desktop-app/app.log"
SVC_AI="KLARWERK-App-Anthropic"    # Reasoner (Pflicht für echte KI, sonst deterministischer Modus)
SVC_TR="KLARWERK-App-Transkript"   # Whisper/OpenAI für Video-Analyse (optional)
ACC="team1"

say()  { /usr/bin/osascript -e "display notification \"$1\" with title \"KLARWERK App\"" >/dev/null 2>&1; }
fail() { /usr/bin/osascript -e "display dialog \"$1\" with title \"KLARWERK App\" buttons {\"OK\"} default button 1 with icon caution" >/dev/null 2>&1; exit 1; }

keychain_get() { /usr/bin/security find-generic-password -s "$1" -a "$ACC" -w 2>/dev/null; }
keychain_ask() { # $1=Service $2=Prompt $3=optional("optional" erlaubt Überspringen)
  local val
  val="$(keychain_get "$1")"
  if [ -n "$val" ]; then printf '%s' "$val"; return 0; fi
  local buttons='{"Abbrechen","Speichern"}'
  [ "$3" = "optional" ] && buttons='{"Überspringen","Speichern"}'
  val="$(/usr/bin/osascript -e "text returned of (display dialog \"$2\n\nWird sicher im macOS-Schlüsselbund gespeichert — nie in Dateien oder Logs.\" with title \"KLARWERK App\" default answer \"\" with hidden answer buttons $buttons default button 2)" 2>/dev/null)"
  if [ -n "$val" ]; then
    /usr/bin/security add-generic-password -U -s "$1" -a "$ACC" -w "$val" >/dev/null 2>&1
    printf '%s' "$val"
  fi
  return 0
}

[ -d "$REPO" ] || fail "Projektordner nicht gefunden: $REPO"
mkdir -p "$(dirname "$LOG")"
echo "=== Start $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$LOG"

# Node finden — ARCHITEKTUR-BEWUSST: auf Apple Silicon muss ein arm64-Node laufen,
# sonst passen die nativen Pakete (esbuild etc.) im Projekt nicht (Rosetta-Falle).
MACH="$(/usr/bin/uname -m)"; WANT="x64"; [ "$MACH" = "arm64" ] && WANT="arm64"
CANDS=""
for c in /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node; do [ -x "$c" ] && CANDS="$CANDS $c"; done
NVMN="$(ls -1 "$HOME"/.nvm/versions/node/*/bin/node 2>/dev/null | sort -V | tail -1)"
[ -n "$NVMN" ] && CANDS="$NVMN $CANDS"
NODE_PICK=""
for c in $CANDS; do
  if [ "$("$c" -p process.arch 2>/dev/null)" = "$WANT" ]; then NODE_PICK="$c"; break; fi
done
[ -z "$NODE_PICK" ] && for c in $CANDS; do NODE_PICK="$c"; break; done
[ -n "$NODE_PICK" ] || fail "Node.js nicht gefunden (nodejs.org installieren)."
NODE_BIN="$(dirname "$NODE_PICK")"
export PATH="$NODE_BIN:$PATH"
echo "Node: $NODE_PICK ($("$NODE_PICK" -p process.arch) fuer $MACH)" >> "$LOG"

# Läuft die App schon? Dann nur Browser öffnen.
if /usr/bin/curl -s --max-time 2 "http://127.0.0.1:$PORT/health" | /usr/bin/grep -q '"status":"ok"'; then
  /usr/bin/open "http://localhost:$PORT"
  exit 0
fi

# Keys aus dem Schlüsselbund (Erststart: Dialoge). Anthropic = Reasoner, Whisper = Video (optional).
AI_KEY="$(keychain_ask "$SVC_AI" "Anthropic-API-Key für den KLARWERK Reasoner (beginnt mit sk-ant-…).\nOhne Key läuft die App im deterministischen Modus — ehrlich gekennzeichnet." optional)"
TR_KEY="$(keychain_ask "$SVC_TR" "Optional: OpenAI-Key für die Video-/Audio-Transkription (Whisper).\nÜberspringen ist ok — die Video-Analyse zeigt dann einen ehrlichen Inaktiv-Hinweis." optional)"

cd "$REPO" || fail "Kann nicht in den Projektordner wechseln."
if [ ! -d node_modules ]; then
  say "Erste Einrichtung: installiere Pakete …"
  npm ci --no-audit --no-fund >> "$LOG" 2>&1 || fail "npm-Installation fehlgeschlagen (desktop-app/app.log)."
fi
if [ ! -f apps/web/dist/index.html ]; then
  say "Baue Oberfläche …"
  if [ ! -d apps/web/node_modules ]; then
    npm --prefix apps/web ci --no-audit --no-fund >> "$LOG" 2>&1 || fail "Frontend-Installation fehlgeschlagen (desktop-app/app.log)."
  fi
  npm --prefix apps/web run build >> "$LOG" 2>&1 || fail "Frontend-Build fehlgeschlagen (desktop-app/app.log)."
fi

say "Starte KLARWERK …"
# Keys nur als Env dieses Prozesses; das Log erhält sie nicht (Server loggt keine Secrets).
ANTHROPIC_API_KEY="$AI_KEY" MEDIA_TRANSCRIBE_API_KEY="$TR_KEY" PORT="$PORT" \
  /usr/bin/nohup npm start >> "$LOG" 2>&1 &

for _ in $(seq 1 40); do
  if /usr/bin/curl -s --max-time 1 "http://127.0.0.1:$PORT/health" | /usr/bin/grep -q '"status":"ok"'; then
    say "KLARWERK läuft — öffne Browser"
    /usr/bin/open "http://localhost:$PORT"
    exit 0
  fi
  sleep 0.5
done
fail "KLARWERK konnte nicht gestartet werden. Details: desktop-app/app.log"
