{
  "name": "klarwerk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "arch": "depcruise --config .dependency-cruiser.cjs services",
    "test": "vitest run",
    "check": "npm run build && npm run lint && npm run arch && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "dependency-cruiser": "^16.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "testcontainers": "^10.13.0"
  },
  "dependencies": {
    "fastify": "^5.0.0"
  }
}
