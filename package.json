{
  "name": "klarwerk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "arch": "depcruise --config .dependency-cruiser.cjs services",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check": "npm run build && npm run lint && npm run arch && npm run test",
    "start": "tsx services/app/src/server.ts",
    "seed:demo": "tsx services/app/src/seed.ts",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "smoke:browser:setup": "playwright install chromium"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "playwright": "^1.49.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "dependency-cruiser": "^16.4.0",
    "testcontainers": "^10.13.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.0.0",
    "jose": "^5.9.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0"
  }
}
